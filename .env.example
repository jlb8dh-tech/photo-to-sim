# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.

# Required for real generation. Without it, the app runs in MOCK mode (returns a sample sim).
ANTHROPIC_API_KEY=

# Which Claude model to use for vision generation. Defaults to a current Claude model.
# ANTHROPIC_MODEL=claude-opus-4-8

# --- ElevenLabs voiceover (optional) ---
# Set this to enable the "Play scenario" buttons. Without it, audio is hidden.
ELEVENLABS_API_KEY=
# Voice + model overrides (defaults: "Rachel" voice, eleven_multilingual_v2).
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Runway video (optional) ---
# Set this to enable "Generate video" (image-to-video from the facility photo).
# Without it, the video panel shows a mock preview. Other features are unaffected.
RUNWAY_API_KEY=
# Overrides (defaults: gen4_turbo, version 2024-11-06, ratio 1280:720).
# RUNWAY_MODEL=gen4_turbo
# RUNWAY_API_VERSION=2024-11-06
# RUNWAY_RATIO=1280:720

# --- Supabase auth (login / signup) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
